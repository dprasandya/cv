	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="sub_period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="company_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="js_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="ol_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="usrname" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.emp_name, b.emp_bank_02, sum(iif(a.sc_type='I',a.total_amount, a.total_amount*(-1))) as total
from hris_salary_harian_report($P{usrname},$P{ol_id},$P{emp_id},$P{js_id}, $P{company_id},$P{sub_period},$P{period},$P{co_id}) a
left join hris_employee b on b.co_id=$P{co_id} and a.emp_id=b.emp_id
group by a.emp_id, a.emp_name, b.emp_bank_02]]>
		</queryString>
		<field name="EMP_NAME" class="java.lang.String"/>
		<field name="EMP_BANK_02" class="java.lang.String"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="period" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
