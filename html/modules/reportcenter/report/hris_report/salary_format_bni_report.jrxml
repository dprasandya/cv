	</parameter>
	<parameter name="emp_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="ol_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="usrname" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.co_name, b.js_name, c.ol_name from company a
left join hris_job_status b on a.co_id=b.co_id and b.js_id=$P{js_id}
left join hris_office_locations c on a.co_id=c.co_id and c.ol_id=$P{ol_id}
where a.co_id=$P{co_id}]]>
	</queryString>
	<field name="CO_NAME" class="java.lang.String"/>
	<field name="JS_NAME" class="java.lang.String"/>
	<field name="OL_NAME" class="java.lang.String"/>
