	</parameter>
	<queryString>
		<![CDATA[select a.co_name, b.js_name, c.ol_name, d.company_name from company a
left join hris_job_status b on a.co_id=b.co_id and b.js_id=$P{js_id}
left join hris_office_locations c on a.co_id=c.co_id and c.ol_id=$P{ol_id}
left join hris_company d on a.co_id=d.co_id and d.company_id=$P{company_id}
where a.co_id=$P{co_id}]]>
	</queryString>
