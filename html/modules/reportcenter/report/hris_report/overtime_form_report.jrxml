	<subDataset name="attendance_1" uuid="5314218f-0a72-4871-80d0-e600287008c0">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, c.job_desc from hris_emp_report_spv a
left join hris_employee b on a.co_id=b.co_id and a.emp_spv_id=b.emp_id
left join hris_job_title c on b.co_id=c.co_id and b.emp_job_id=c.job_id
where a.co_id=$P{co_id} and a.emp_id=$P{emp_id}
order by a.reporting_method asc]]>
		</queryString>
		<field name="REPORTING_METHOD" class="java.lang.String"/>
		<field name="EMP_SPV_ID" class="java.lang.String"/>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="USERINPUT" class="java.lang.String"/>
		<field name="USEREDIT" class="java.lang.String"/>
		<field name="TIMEINPUT" class="java.sql.Timestamp"/>
		<field name="TIMEEDIT" class="java.sql.Timestamp"/>
		<field name="EMP_SPV_NAME" class="java.lang.String"/>
		<field name="APPROVAL_METHOD" class="java.lang.String"/>
		<field name="JOB_DESC" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<subDataset name="overtime_detail" uuid="7dd499b9-0159-444c-8fda-a800df19586f">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="seq_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from hris_overtime_request_detail where co_id=$P{co_id} and emp_id=$P{emp_id} and seq_id=$P{seq_id}]]>
		</queryString>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="OUTPUT_DESC" class="java.lang.String"/>
		<field name="JOB_DESC" class="java.lang.String"/>
		<field name="TIME_OUT" class="java.sql.Time"/>
		<field name="TIME_IN" class="java.sql.Time"/>
		<field name="SEQ_ID_DETAIL" class="java.lang.Integer"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="seq_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.*, b.overtime_date, c.co_name, d.company_name, e.ol_name, f.dept_name, g.job_desc, a.emp_first_name||' '||coalesce(a.emp_midle_name,'')||' '||coalesce(a.emp_last_name,'') as emp_name from hris_employee a
inner join hris_overtime_request b on a.co_id=b.co_id and a.emp_id=b.emp_id and b.seq_id=$P{seq_id}
left join company c on a.co_id=c.co_id
left join hris_company d on a.co_id=d.co_id and a.emp_company_id=d.company_id
left join hris_office_locations e on a.co_id=e.co_id and a.emp_ol_id=e.ol_id
left join hris_department f on a.co_id=f.co_id and a.emp_dept_id=f.dept_id
left join hris_job_title g on a.co_id=g.co_id and a.emp_job_id=g.job_id
where a.co_id=$P{co_id} and a.user_id=$P{user_id}]]>
	</queryString>
