		</parameter>
		<queryString>
			<![CDATA[select a.*,  b.rate_nominal as admin_bank, lpad( a.id_sort , 3, '0')||a.sc_name as new_sc_name from hris_salary_report_pajak($P{ol_id},$P{emp_id},$P{js_id}, $P{company_id},$P{sub_period},$P{period},$P{co_id}) a
left join hris_Salary_component b on a.co_id=b.co_id and b.sc_id='ADB'
order by a.sc_type, a.id_sort,a.emp_id asc]]>
		</queryString>
