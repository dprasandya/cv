	<subDataset name="employee" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="company_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="js_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="ol_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="usrname" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.emp_id, b.company_id, a.emp_first_date, a.emp_end_date, coalesce(a.emp_first_name,'')||iif(coalesce(a.emp_midle_name,'')='','',' '||a.emp_midle_name)||iif(coalesce(a.emp_last_name,'')='','',' '||a.emp_last_name) as emp_name, b.company_name, e.js_name, iif(a.status=1,'AKTIF','NON AKTIF') as status, e.js_name, a.emp_join_date, f.nominal as jkes, g.nominal as tk, iif(k.status=1, h.amount, 0) as gj, h.pay_frequency as frequency_gj, iif(a.emp_marital_status='M','NIKAH', iif(a.emp_marital_status='S','BELUM NIKAH', null)) as status_pernikahan, a.emp_birth_date, a.emp_tlp, a.emp_address, a.emp_city, iif(a.emp_gender='M','Laki-laki', iif(a.emp_gender='F','Perempuan', a.emp_gender)) as gender, a.emp_pos_id, a.emp_religion, a.emp_blood, a.emp_bank_02 as nomor_rekening, a.emp_ktp, a.emp_group_id, a.emp_ptkp_id
from hris_employee a
left join hris_company b on a.co_id=b.co_id and a.emp_company_id=b.company_id
left join hris_job_status e on a.co_id=e.co_id and a.emp_js_id=e.js_id
left join hris_emp_bpjs f on a.co_id=f.co_id and a.emp_id=f.emp_id and f.sc_id='BSO' and f.sc_type='O'
left join hris_emp_bpjs g on a.co_id=g.co_id and a.emp_id=g.emp_id and g.sc_id='JHO' and g.sc_type='O'
left join hris_emp_salary h on a.co_id=h.co_id and a.emp_id=h.emp_id and h.sc_id='GPI' and h.sc_type='I'
inner join hris_view_company i on a.co_id=i.co_id and a.emp_company_id=i.company_id and i.status='1' and i.usrname=$P{usrname}
inner join hris_view_job_status j on a.co_id=j.co_id and a.emp_js_id=j.js_id and j.status='1' and j.usrname=$P{usrname}
left join hris_view_salary_js k on a.co_id=k.co_id and a.emp_js_id=k.js_id and k.usrname=$P{usrname}
left join hris_view_office_locations l on a.co_id=l.co_id and a.emp_ol_id=l.ol_id and l.status='1' and l.usrname=$P{usrname}
where a.co_id=$P{co_id} and coalesce(a.emp_company_id,'') like $P{company_id}||'%' and coalesce(a.emp_js_id,'') like $P{js_id}||'%' and coalesce(a.emp_ol_id,'') like $P{ol_id}||'%'
order by a.emp_company_id, a.emp_js_id, a.emp_id asc]]>
		</queryString>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="COMPANY_ID" class="java.lang.String"/>
		<field name="EMP_FIRST_DATE" class="java.sql.Date"/>
		<field name="EMP_END_DATE" class="java.sql.Date"/>
		<field name="EMP_NAME" class="java.lang.String"/>
		<field name="COMPANY_NAME" class="java.lang.String"/>
		<field name="JS_NAME" class="java.lang.String"/>
		<field name="STATUS" class="java.lang.String"/>
		<field name="EMP_JOIN_DATE" class="java.sql.Date"/>
		<field name="JKES" class="java.math.BigDecimal"/>
		<field name="TK" class="java.math.BigDecimal"/>
		<field name="GJ" class="java.math.BigDecimal"/>
		<field name="FREQUENCY_GJ" class="java.lang.String"/>
		<field name="STATUS_PERNIKAHAN" class="java.lang.String"/>
		<field name="EMP_BIRTH_DATE" class="java.sql.Date"/>
		<field name="EMP_TLP" class="java.lang.String"/>
		<field name="EMP_ADDRESS" class="java.lang.String"/>
		<field name="EMP_CITY" class="java.lang.String"/>
		<field name="GENDER" class="java.lang.String"/>
		<field name="EMP_POS_ID" class="java.lang.String"/>
		<field name="EMP_RELIGION" class="java.lang.String"/>
		<field name="EMP_BLOOD" class="java.lang.String"/>
		<field name="NOMOR_REKENING" class="java.lang.String"/>
		<field name="EMP_KTP" class="java.lang.String"/>
		<field name="EMP_GROUP_ID" class="java.lang.String"/>
		<field name="EMP_PTKP_ID" class="java.lang.String"/>
