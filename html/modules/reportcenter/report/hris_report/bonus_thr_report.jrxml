		</parameter>
		<parameter name="usrname" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.* from hris_bonus_thr_report($P{bt_type},$P{usrname},$P{ol_id},$P{emp_id},$P{js_id},$P{company_id}, $P{period},$P{co_id}) a
where coalesce(a.total_amount,0) > 0
order by a.group_id, a.emp_id asc]]>
		</queryString>
		<field name="GROUP_ID" class="java.lang.String"/>
		<field name="SALARY" class="java.math.BigDecimal"/>
