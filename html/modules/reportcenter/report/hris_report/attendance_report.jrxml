	<subDataset name="attendance" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="fromdate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="todate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from hris_attendance_biofinger($P{todate},$P{fromdate},$P{emp_id},$P{co_id}) order by attendance_date asc]]>
		</queryString>
		<field name="LATE_TIME" class="java.math.BigDecimal"/>
		<field name="DURATION" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="STATUS" class="java.lang.String"/>
		<field name="TIME_OUT" class="java.sql.Time"/>
		<field name="TIME_IN" class="java.sql.Time"/>
		<field name="DAY_NAME" class="java.lang.String"/>
		<field name="ATTENDANCE_DATE" class="java.sql.Date"/>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="Alpha" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("A") ? 1 : 0]]></variableExpression>
		</variable>
		<variable name="hadir" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("H") ? 1 :0]]></variableExpression>
		</variable>
		<variable name="ijin" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("I") ? 1 :0]]></variableExpression>
		</variable>
		<variable name="sakit" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("S") ? 1 :0]]></variableExpression>
		</variable>
		<variable name="cuti" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("C") ? 1 :0]]></variableExpression>
		</variable>
		<variable name="dinas_luar" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("D") ? 1 : 0]]></variableExpression>
		</variable>
		<variable name="telat" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{LATE_TIME}]]></variableExpression>
		</variable>
		<variable name="off_libur" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("O") ? 1 : 0]]></variableExpression>
		</variable>
		<variable name="sakit_tanpa_ket" class="java.lang.Integer" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("K") ? 1 : 0]]></variableExpression>
		</variable>
		<variable name="Wfh" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("W") ? 1 : 0]]></variableExpression>
		</variable>
		<variable name="Isoman" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{STATUS}.equals("M") ? 1 : 0]]></variableExpression>
		</variable>
	</subDataset>
