	<subDataset name="overtime" uuid="5314218f-0a72-4871-80d0-e600287008c0">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.time_in, a.time_out, a.remarks, b.*
from hris_overtime a
left join hris_overtime_detail b on a.co_id=b.co_id and a.emp_id=b.emp_id and a.overtime_date=b.overtime_date
where a.co_id=$P{co_id} and a.emp_id=$P{emp_id} and a.status=1 and (select period from get_period(a.overtime_date))=$P{period}
order by a.overtime_date, b.seq_id asc]]>
		</queryString>
		<field name="TIME_IN" class="java.sql.Time"/>
		<field name="TIME_OUT" class="java.sql.Time"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="RATE_TOTAL" class="java.math.BigDecimal"/>
		<field name="RATE_VALUE" class="java.math.BigDecimal"/>
		<field name="RATE_HOURS" class="java.lang.Integer"/>
		<field name="TIME_HOURS" class="java.lang.Integer"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="OVERTIME_DATE" class="java.sql.Date"/>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="rate_total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{RATE_TOTAL}]]></variableExpression>
		</variable>
		<group name="overtime_date">
			<groupExpression><![CDATA[$F{OVERTIME_DATE}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="emp_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="period" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.*, b.co_name from hris_employee_s($P{emp_id},$P{co_id}) a
left join company b on a.co_id=b.co_id]]>
	</queryString>
