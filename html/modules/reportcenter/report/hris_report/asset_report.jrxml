		<field name="ASSET_TYPE" class="java.lang.String"/>
		<field name="ASSET_NAME" class="java.lang.String"/>
		<field name="ASSET_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="COMPANY_ID" class="java.lang.String"/>
		<field name="OL_ID" class="java.lang.String"/>
		<field name="EMP_ID" class="java.lang.String"/>
		<field name="REQUEST_TYPE" class="java.lang.String"/>
		<field name="EMP_NAME" class="java.lang.String"/>
		<field name="OL_NAME" class="java.lang.String"/>
		<field name="COMPANY_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
