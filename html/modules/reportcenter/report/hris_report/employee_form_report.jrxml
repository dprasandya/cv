	<subDataset name="work_experience" uuid="2c831696-2235-4113-90ae-8070f9a5be1d">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.job_desc, c.dept_name from hris_emp_work_experience a
left join hris_job_title b on a.co_id=b.co_id and a.job_id=b.job_id
left join hris_department c on a.co_id=c.co_id and a.dept_id=c.dept_id
where a.co_id=$P{co_id} and a.emp_id=$P{emp_id}]]>
		</queryString>
		<field name="END_DATE" class="java.sql.Date"/>
