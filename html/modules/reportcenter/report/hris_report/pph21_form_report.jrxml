			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from hris_ptkp_rates_s($P{sub_period},$P{period},$P{emp_id},$P{co_id})]]>
		</queryString>
		<field name="AMOUNT_THR" class="java.math.BigDecimal"/>
		<field name="AMOUNT_BONUS" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT_GP" class="java.math.BigDecimal"/>
		<field name="AMOUNT" class="java.math.BigDecimal"/>
		<field name="RATE_NAME" class="java.lang.String"/>
		<field name="RATE" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{AMOUNT}]]></variableExpression>
		</variable>
		<variable name="total_bonus" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{AMOUNT_BONUS}]]></variableExpression>
		</variable>
		<variable name="total_thr" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{AMOUNT_THR}]]></variableExpression>
		</variable>
	</subDataset>
