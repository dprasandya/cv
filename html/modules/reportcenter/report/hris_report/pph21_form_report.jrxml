	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="sub_period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from HRIS_PPH21_FORM($P{sub_period},$P{emp_id},$P{period},$P{co_id}) order by sc_type, id_sort asc]]>
		</queryString>
		<field name="NPWP" class="java.lang.String"/>
		<field name="PTKP_ID" class="java.lang.String"/>
		<field name="TOTAL_AMOUNT_THR" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT_BONUS" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT" class="java.math.BigDecimal"/>
		<field name="AMOUNT" class="java.math.BigDecimal"/>
		<field name="DAY_INDEX" class="java.math.BigDecimal"/>
		<field name="PAY_FREQUENCY" class="java.lang.String"/>
		<field name="SC_TYPE" class="java.lang.String"/>
		<field name="SC_NAME" class="java.lang.String"/>
		<field name="SC_ID" class="java.lang.String"/>
		<field name="ID_SORT" class="java.lang.Integer"/>
		<field name="PERIOD" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="sub_total" class="java.math.BigDecimal" resetType="Group" resetGroup="sc_type" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_AMOUNT}]]></variableExpression>
		</variable>
		<variable name="grand_total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{SC_TYPE}.equals("I") ? $F{TOTAL_AMOUNT} : ($F{TOTAL_AMOUNT}.doubleValue()*(-1))]]></variableExpression>
		</variable>
		<variable name="sub_total_bonus" class="java.math.BigDecimal" resetType="Group" resetGroup="sc_type" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_AMOUNT_BONUS}]]></variableExpression>
		</variable>
		<variable name="sub_total_thr" class="java.math.BigDecimal" resetType="Group" resetGroup="sc_type" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_AMOUNT_THR}]]></variableExpression>
		</variable>
		<variable name="grand_total_bonus" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{SC_TYPE}.equals("I") ? $F{TOTAL_AMOUNT_BONUS} : ($F{TOTAL_AMOUNT_BONUS}.doubleValue()*(-1))]]></variableExpression>
		</variable>
		<variable name="grand_total_thr" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{SC_TYPE}.equals("I") ? $F{TOTAL_AMOUNT_THR} : ($F{TOTAL_AMOUNT_THR}.doubleValue()*(-1))]]></variableExpression>
		</variable>
		<group name="sc_type">
			<groupExpression><![CDATA[$F{SC_TYPE}]]></groupExpression>
		</group>
	</subDataset>
	<subDataset name="Ptkp" uuid="b71785af-457a-4956-b468-fbdcec774362">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="sub_period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select b.ptkp_id, b.ptkp_name, b.wp_personal, b.wp_additional, b.wp_total, sum(iif(sc_type='I', a.total_amount, a.total_amount*(-1)))*12 as total_amount, sum(iif(sc_type='I', a.total_amount_bonus, a.total_amount_bonus*(-1))) as total_amount_bonus, sum(iif(sc_type='I', a.total_amount_thr, a.total_amount_thr*(-1))) as total_amount_thr
from hris_pph21_form($P{sub_period},$P{emp_id},$P{period},$P{co_id}) a
left join hris_ptkp b on a.co_id=b.co_id and a.ptkp_id=b.ptkp_id
group by b.ptkp_id, b.ptkp_name, b.wp_personal, b.wp_additional, b.wp_total]]>
		</queryString>
		<field name="PTKP_ID" class="java.lang.String"/>
		<field name="PTKP_NAME" class="java.lang.String"/>
		<field name="WP_PERSONAL" class="java.math.BigDecimal"/>
		<field name="WP_ADDITIONAL" class="java.math.BigDecimal"/>
		<field name="WP_TOTAL" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT_BONUS" class="java.math.BigDecimal"/>
		<field name="TOTAL_AMOUNT_THR" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<subDataset name="rates" uuid="ec6b23b0-dd68-446d-9db5-d16af33c533d">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="emp_id" class="java.lang.String">
