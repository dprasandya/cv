	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.item_name, c.cust_name from work_order_letter_detail a
left join items b on a.co_id=b.co_id and a.item_id=b.item_id and a.unit_id=b.unit_id
left join customer c on a.co_id=c.co_id and a.cust_id=c.cust_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
		</queryString>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="CUST_ID" class="java.lang.String"/>
		<field name="FOR_DOC_ID" class="java.lang.String"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="ITEM_NAME" class="java.lang.String"/>
		<field name="CUST_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.*, b.co_name, b.address, b.city from work_order_letter a
left join company b on a.co_id=b.co_id
where a.co_id=$P{co_id}]]>
	</queryString>
