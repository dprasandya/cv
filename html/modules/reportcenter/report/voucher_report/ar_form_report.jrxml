	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.unit_id, a.qty, a.price, a.qty*a.price as total, a.qty*a.price_ppn as ppn, a.qty*a.price_pph as pph, a.qty*a.total_price as grandtotal, b.tax_name, b.rate_ppn, b.rate_pph, a.remarks
from ar_sale a
left join tax b on a.co_id=b.co_id and a.tax_id=b.tax_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
		</queryString>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="PRICE" class="java.math.BigDecimal"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="PPN" class="java.math.BigDecimal"/>
		<field name="PPH" class="java.math.BigDecimal"/>
		<field name="GRANDTOTAL" class="java.math.BigDecimal"/>
		<field name="TAX_NAME" class="java.lang.String"/>
		<field name="RATE_PPN" class="java.math.BigDecimal"/>
		<field name="RATE_PPH" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.doc_date, a.cust_id, c.cust_name, c.city, c.mobile_phone, c.home_phone, c.address, b.co_name, b.city as co_city, b.address as co_address, b.phone as co_phone, a.tax_no, a.tax_date, a.item_id, d.item_name, a.unit_building_id, e.unit_building_name
from ar_sale a
left join company b on a.co_id=b.co_id
left join customer c on a.co_id=c.co_id and a.cust_id=c.cust_id
left join items d on a.co_id=d.co_id and a.item_id=d.item_id and a.unit_id=d.unit_id
left join unit_building e on a.co_id=e.co_id and a.unit_building_id=e.unit_building_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
	</queryString>
	<field name="DOC_DATE" class="java.sql.Date"/>
	<field name="CUST_ID" class="java.lang.String"/>
	<field name="CUST_NAME" class="java.lang.String"/>
	<field name="CITY" class="java.lang.String"/>
	<field name="MOBILE_PHONE" class="java.lang.String"/>
	<field name="HOME_PHONE" class="java.lang.String"/>
