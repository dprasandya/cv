	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="tax_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select iif(coalesce(a.item_id,'')<>'',a.item_id,a.coa_id) as item_id, iif(coalesce(a.item_id,'')<>'',c.item_name, b.coa_name) as item_name, a.unit_id, a.qty, a.price, a.qty*a.price as total, a.total*(d.rate_ppn/100) as ppn, a.total*(d.rate_pph/100) as pph, d.tax_name, d.rate_ppn, d.rate_pph
from ap_invoice_detail a
left join coa b on a.co_id=b.co_id and a.coa_id=b.coa_id
left join items c on a.co_id=c.co_id and a.item_id=c.item_id
left join tax d on a.co_id=d.co_id and d.tax_id=$P{tax_id}
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
		</queryString>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="ITEM_NAME" class="java.lang.String"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="PRICE" class="java.math.BigDecimal"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="PPN" class="java.math.BigDecimal"/>
		<field name="PPH" class="java.math.BigDecimal"/>
		<field name="TAX_NAME" class="java.lang.String"/>
		<field name="RATE_PPN" class="java.math.BigDecimal"/>
		<field name="RATE_PPH" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<variable name="ppn" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPN}]]></variableExpression>
		</variable>
		<variable name="pph" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPH}]]></variableExpression>
		</variable>
		<variable name="grand_total" class="java.math.BigDecimal">
			<variableExpression><![CDATA[$V{total}.add($V{ppn}).subtract($V{pph})]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.doc_date, a.vend_id, c.vend_name, c.city, c.phone, c.address, b.co_name, b.city as co_city, b.address as co_address, b.phone as co_phone, a.tax_no, a.tax_date, a.tax_NO, A.TAX_ID
from ap_invoice a
left join company b on a.co_id=b.co_id
left join vendor c on a.co_id=c.co_id and a.vend_id=c.vend_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
	</queryString>
	<field name="DOC_DATE" class="java.sql.Date"/>
	<field name="VEND_ID" class="java.lang.String"/>
	<field name="VEND_NAME" class="java.lang.String"/>
	<field name="CITY" class="java.lang.String"/>
	<field name="PHONE" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
	<field name="CO_NAME" class="java.lang.String"/>
	<field name="CO_CITY" class="java.lang.String"/>
	<field name="CO_ADDRESS" class="java.lang.String"/>
	<field name="CO_PHONE" class="java.lang.String"/>
	<field name="TAX_NO" class="java.lang.String"/>
	<field name="TAX_DATE" class="java.sql.Date"/>
	<field name="TAX_ID" class="java.lang.String"/>
