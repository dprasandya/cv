	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="tax_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[]]>
		</queryString>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="ITEM_NAME" class="java.lang.String"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="PRICE" class="java.math.BigDecimal"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="PPN" class="java.math.BigDecimal"/>
		<field name="PPH" class="java.math.BigDecimal"/>
		<field name="TAX_NAME" class="java.lang.String"/>
		<field name="RATE_PPN" class="java.math.BigDecimal"/>
		<field name="RATE_PPH" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<variable name="ppn" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPN}]]></variableExpression>
		</variable>
		<variable name="pph" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPH}]]></variableExpression>
		</variable>
		<variable name="grand_total" class="java.math.BigDecimal">
			<variableExpression><![CDATA[$V{total}.add($V{ppn}).subtract($V{pph})]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="unit_building_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.co_id, a.unit_building_id, a.unit_building_name, a.project_id, b.project_name, a.cluster_id, c.cluster_name, a.facing_id, d.facing_name, a.building_id, e.building_name, a.floor_id, a.area_m2, f.qty, f.price, f.price_ppn, f.price_pph, f.total_price, f.total, g.identity_no, coalesce(g.first_name,'')||' '||coalesce(g.last_name,'') as identity_name, iif(g.gender='M', 'Male','Female') as gender,  g.blood_type, case g.religion when'M' then 'Muslem' when 'B'then'Buddha' when 'P' then'Protestan' when 'N' then 'Nasrani' when 'H' then 'Hindu' end as religion, iif(g.merriage_status='M','Meriage','Single') as merriage_status, g.city, g.nationality, g.mobile_phone, g.home_phone, g.address, g.identity_type, g.cust_npwp, g.cust_contact, g.cust_name,g.npwp, g.sales_id, h.sales_name, i.payment_name, f.advance_value, f.installment_Advance, f.start_billing, f.remarks, j.city as city_company
        from unit_building a
        left join project b on a.co_id=b.co_id and a.project_id=b.project_id
        left join cluster c on a.co_id=c.co_id and a.cluster_id=c.cluster_id
        left join facing d on a.co_id=d.co_id and a.facing_id=d.facing_id
        left join building_type e on a.co_id=e.co_id and a.building_id=e.building_id
        left join registration_unit f on a.co_id=f.co_id and a.unit_building_id=f.unit_building_id and a.project_id=f.project_id and f.status<>2
        left join registration g on f.co_id=g.co_id and f.registration_id=g.registration_id
        left join salesman h on g.co_id=h.co_id and g.sales_id=h.sales_id
        left join payment_method i on f.co_id=i.co_id and f.payment_id=i.payment_id
left join company j on a.co_id=j.co_id
        where a.co_id=$P{co_id} and a.unit_building_id=$P{unit_building_id}]]>
	</queryString>
