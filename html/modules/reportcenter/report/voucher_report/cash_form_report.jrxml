	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*,  b.coa_name
from cashbook_detail a
left join coa b on a.co_id=b.co_id and a.coa_id=b.coa_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
		</queryString>
		<field name="NOMINAL" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="COA_ID" class="java.lang.String"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="COA_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{NOMINAL}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.doc_date, a.doc_type, iif(a.doc_type='O', a.vend_id, a.cust_id) as vend_cust_id, iif(a.doc_type='O', c.vend_name, d.cust_name) as vend_cust_name, c.city, c.phone, c.address, b.co_name, b.city as co_city, b.address as co_address, b.phone as co_phone, a.nominal, e.cash_name
from cashbook a
left join company b on a.co_id=b.co_id
left join vendor c on a.co_id=c.co_id and a.vend_id=c.vend_id
left join customer d on a.co_id=d.co_id and a.cust_id=d.cust_id
left join cashbank e on a.co_id=e.co_id and a.cash_id=e.cash_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
	</queryString>
	<field name="DOC_DATE" class="java.sql.Date"/>
	<field name="DOC_TYPE" class="java.lang.String"/>
	<field name="VEND_CUST_ID" class="java.lang.String"/>
	<field name="VEND_CUST_NAME" class="java.lang.String"/>
	<field name="CITY" class="java.lang.String"/>
	<field name="PHONE" class="java.lang.String"/>
	<field name="ADDRESS" class="java.lang.String"/>
	<field name="CO_NAME" class="java.lang.String"/>
	<field name="CO_CITY" class="java.lang.String"/>
	<field name="CO_ADDRESS" class="java.lang.String"/>
	<field name="CO_PHONE" class="java.lang.String"/>
	<field name="NOMINAL" class="java.math.BigDecimal"/>
	<field name="CASH_NAME" class="java.lang.String"/>
