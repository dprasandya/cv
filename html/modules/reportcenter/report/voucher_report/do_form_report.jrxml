	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select b.city, b.address, a.unit_id, sum(iif(a.doc_type='D',b.qty, b.qty*(-1))) as qty
from deliveryorder a
inner join deliveryorder_address_send b on a.co_id=b.co_id and a.doc_id=b.doc_id and b.status=1
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}
group by b.city, b.address, a.unit_id
having sum(iif(a.doc_type='D',b.qty, b.qty*(-1))) > 0]]>
		</queryString>
		<field name="CITY" class="java.lang.String"/>
		<field name="ADDRESS" class="java.lang.String"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.*, b.cust_name,B.cust_name, B.city, B.phone, B.address, c.item_name, d.co_name from deliveryorder a
left join customer b on a.co_id=b.co_id and a.cust_id=b.cust_id
left join items c on a.co_id=c.co_id and a.item_id=c.item_id and a.unit_id=c.unit_id
left join company d on a.co_id=d.co_id
where a.co_id=$P{co_id} and a.doc_id=$P{doc_id}]]>
	</queryString>
