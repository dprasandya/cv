	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="project_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="cluster_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="building_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.project_name, c.cluster_name, d.building_name, e.facing_name
from unit_building a
left join project b on a.co_id=b.co_id and a.project_id=b.project_id
left join cluster c on a.co_id=c.co_id and a.cluster_id=c.cluster_id
left join building_type d on a.co_id=d.co_id and a.building_id=d.building_id
left join facing e on a.co_id=e.co_id and a.facing_id=e.facing_id
where a.co_id=$P{co_id} and a.project_id like $P{project_id}||'%' and a.cluster_id like $P{cluster_id}||'%' and a.building_id like $P{building_id}||'%'
order by b.project_name, unit_building_status asc]]>
		</queryString>
		<field name="TIMEEDIT" class="java.sql.Timestamp"/>
		<field name="TIMEINPUT" class="java.sql.Timestamp"/>
		<field name="USEREDIT" class="java.lang.String"/>
		<field name="USERINPUT" class="java.lang.String"/>
		<field name="STATUS" class="java.lang.String"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="UNIT_BUILDING_NAME" class="java.lang.String"/>
		<field name="UNIT_BUILDING_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="PROJECT_ID" class="java.lang.String"/>
		<field name="AREA_M2" class="java.math.BigDecimal"/>
		<field name="FACING_ID" class="java.lang.String"/>
		<field name="BUILDING_ID" class="java.lang.String"/>
		<field name="CLUSTER_ID" class="java.lang.String"/>
		<field name="FLOOR_ID" class="java.lang.String"/>
		<field name="UNIT_BUILDING_STATUS" class="java.lang.String"/>
		<field name="PRICE_M2" class="java.math.BigDecimal"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="PRICE_RENT_M2" class="java.math.BigDecimal"/>
		<field name="TOTAL_RENT" class="java.math.BigDecimal"/>
		<field name="RENT_STATUS" class="java.lang.String"/>
		<field name="PROJECT_NAME" class="java.lang.String"/>
		<field name="CLUSTER_NAME" class="java.lang.String"/>
		<field name="BUILDING_NAME" class="java.lang.String"/>
		<field name="FACING_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<group name="project">
			<groupExpression><![CDATA[$F{PROJECT_NAME}]]></groupExpression>
		</group>
		<group name="unit_building_status">
			<groupExpression><![CDATA[$F{UNIT_BUILDING_STATUS}]]></groupExpression>
		</group>
	</subDataset>
