	</parameter>
	<parameter name="doc_date" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="nominal" class="java.math.BigDecimal">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.*, b.doc_date from ar_sale_payment_detail a
inner join ar_sale_payment b on a.co_id=b.co_id and a.doc_id=b.doc_id and b.status<>0 and b.doc_date<=$P{doc_date}
left join cancel_transactions c on b.co_id=c.co_id and b.doc_id=c.for_doc_id and c.status=1 and c.doc_date<=$P{doc_date}
where a.co_id=$P{co_id} and a.for_doc_av=$P{doc_id}]]>
	</queryString>
