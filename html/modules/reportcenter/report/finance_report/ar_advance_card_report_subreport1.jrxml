	<subDataset name="TableData" uuid="9590d883-9b4c-48b1-b4f2-f904f564edd5">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_date" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="nominal" class="java.math.BigDecimal">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.doc_id, a.nominal, a.remarks, b.doc_date from ar_sale_payment_detail a
inner join ar_sale_payment b on a.co_id=b.co_id and a.doc_id=b.doc_id and b.status<>0 and b.doc_date<=$P{doc_date}
left join cancel_transactions c on b.co_id=c.co_id and b.doc_id=c.for_doc_id and c.status=1 and c.doc_date<=$P{doc_date}
where a.co_id=$P{co_id} and a.for_doc_av=$P{doc_id}
union all
select a.doc_id, a.nominal, a.remarks, a.doc_date
from refund a
where a.co_id=$P{co_id} and a.for_doc_id=$P{doc_id} and a.doc_type='AR' and doc_date<=$P{doc_date}]]>
		</queryString>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="NOMINAL" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="nominal" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{NOMINAL}]]></variableExpression>
		</variable>
		<variable name="outstanding" class="java.math.BigDecimal">
			<variableExpression><![CDATA[$P{nominal}.subtract($V{nominal})]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="doc_id" class="java.lang.String">
