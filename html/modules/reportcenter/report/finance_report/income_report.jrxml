		</parameter>
		<queryString>
			<![CDATA[select * from rpt_income($P{item_id},$P{cust_id},$P{todate},$P{fromdate},$P{co_id})]]>
		</queryString>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
