	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_date" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="project_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="costcode_type" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="costcode_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.costcode_name, c.coa_name, d.project_name
from costcode_rpt a
left join costcode b on a.co_id=b.co_id and a.costcode_id=b.costcode_id
left join coa c on b.co_id=c.co_id and b.coa_id=c.coa_id
left join project d on a.co_id=d.co_id and a.project_id=d.project_id
where a.co_id=$P{co_id} and a.doc_type=$P{costcode_type} and a.project_id like $P{project_id}||'%' and a.costcode_id like $P{costcode_id}||'%' and a.doc_date<=$P{doc_date}]]>
		</queryString>
		<field name="REMAKS" class="java.lang.String"/>
		<field name="NOMINAL" class="java.math.BigDecimal"/>
		<field name="COSTCODE_ID" class="java.lang.String"/>
		<field name="PROJECT_ID" class="java.lang.String"/>
		<field name="VEND_ID" class="java.lang.String"/>
		<field name="CUST_ID" class="java.lang.String"/>
		<field name="MODULE" class="java.lang.String"/>
		<field name="DOC_TYPE" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="PROJECT_TYPE" class="java.lang.String"/>
		<field name="COSTCODE_NAME" class="java.lang.String"/>
		<field name="COA_NAME" class="java.lang.String"/>
		<field name="PROJECT_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="value" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{NOMINAL}]]></variableExpression>
		</variable>
	</subDataset>
