	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="project_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="unit_building_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.costcode_name, c.unit_building_name, d.project_name, d.net_effective, e.net_effective_current
from sales_recognition_detail a
left join costcode b on a.co_id=b.co_id and a.costcode_id=b.costcode_id
left join unit_building c on a.co_id=c.co_id and a.unit_building_id=c.unit_building_id
left join project d on a.co_id=d.co_id and a.project_id=d.project_id
left join sales_recognition e on a.co_id=d.co_id and a.doc_id=e.doc_id
where a.co_id=$P{co_id} and (select period from get_period(a.doc_date))=$P{period} and a.project_id like $P{project_id}||'%']]>
		</queryString>
		<field name="PROJECT_COST" class="java.math.BigDecimal"/>
		<field name="UNIT_BUILDING_ID" class="java.lang.String"/>
		<field name="PROJECT_ID" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="AREA_M2" class="java.math.BigDecimal"/>
		<field name="COSTCODE_ID" class="java.lang.String"/>
		<field name="COSTCODE_NAME" class="java.lang.String"/>
		<field name="UNIT_BUILDING_NAME" class="java.lang.String"/>
		<field name="PROJECT_NAME" class="java.lang.String"/>
		<field name="NET_EFFECTIVE" class="java.math.BigDecimal"/>
		<field name="NET_EFFECTIVE_CURRENT" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="project_cost" class="java.math.BigDecimal" resetType="Group" resetGroup="doc_id" calculation="Sum">
			<variableExpression><![CDATA[$F{PROJECT_COST}]]></variableExpression>
		</variable>
		<group name="doc_id">
			<groupExpression><![CDATA[$F{DOC_ID}]]></groupExpression>
		</group>
	</subDataset>
