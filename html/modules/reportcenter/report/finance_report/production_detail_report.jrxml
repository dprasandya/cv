	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="tax_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="type" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="period" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="group" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from(
select a.doc_id as for_doc_id, a.doc_date, b.coa_id, c.coa_name, b.qty*b.price as total, b.remarks, iif(a.doc_type='S', 'S Leading Ramp', iif(a.doc_type='V','Vertical Sterilizer', iif(a.doc_type='B','Boiler', iif(a.doc_type='L','Kernel', iif(a.doc_type='I','Klarifikasi', iif(a.doc_type='H','Power House', iif(a.doc_type='W','Workshop', iif(a.doc_type='T','Threser', iif(a.doc_type='R','Others', iif(a.doc_type='C','Limbah', iif(a.doc_type='J','Sample Produk', iif(a.doc_type='N','Laboratorium', null)))))))))))) as doc_type, iif(a.doc_type='R','BIAYA TIDAK LANGSUNG', 'PKS') as group_name
from ap_invoice a
left join ap_invoice_detail b on a.co_id=b.co_id and a.doc_id=b.doc_id
left join coa c on b.co_id=c.co_id and b.coa_id=c.coa_id
left join cancel_transactions d on a.co_id=d.co_id and a.doc_id=d.for_doc_id and d.status=1 and d.doc_type='AP' and (select period from get_period(d.doc_date))<=$P{period}
where a.co_id=$P{co_id} and a.status<>0 and coalesce(a.for_doc_id,'') like $P{doc_id}||'%' and a.doc_type in('S','V','T','B','I','L','H','W','R','C','J','N') and a.doc_type like $P{type}||'%' and (select period from get_period(a.doc_date)) like $P{period}||'%' and d.doc_id is null
union all
select a.doc_id as for_doc_id, a.doc_date, b.coa_id, d.coa_name, b.nominal*(-1) as total, b.remarks, 'Deduction' as doc_type, 'PKS' as group_name
from ap_invoice_payment a
left join ap_invoice_payment_detail b on a.co_id=b.co_id and a.doc_id=b.doc_id
inner join ap_invoice c on b.co_id=c.co_id and c.status=1 and b.for_doc_id=c.doc_id and c.doc_type in('S','V','T','B','I','L','H','W','R','C','J','N') and coalesce(c.for_doc_id,'') like $P{doc_id}||'%'
left join coa d on b.co_id=d.co_id and b.coa_id=d.coa_id
left join cancel_transactions e on a.co_id=e.co_id and a.doc_id=e.for_doc_id and e.status=1 and e.doc_type='PD' and (select period from get_period(e.doc_date))<=$P{period}
where a.co_id=$P{co_id} and a.status<>0 and a.doc_type='D' and (select period from get_period(a.doc_date)) like $P{period}||'%' and e.doc_id is null
union all
select a.doc_id as for_doc_id, a.doc_date, b.item_id as coa_id, c.item_name as coa_name, b.total, b.remarks, 'Pemakian TBS' as doc_type, 'TBS' as group_name
from production a
inner join production_rm b on a.co_id=b.co_id and a.doc_id=b.doc_id
left join items c on b.co_id=c.co_id and b.item_id=c.item_id and b.unit_id=c.unit_id
left join cancel_transactions d on a.co_id=d.co_id and a.doc_id=d.for_doc_id and d.status=1 and d.doc_type='PR' and (select period from get_period(d.doc_date))<=$P{period}
where a.co_id=$P{co_id} and a.status<>0 and a.doc_id like $P{doc_id}||'%' and (select period from get_period(a.doc_date)) like $P{period}||'%' and d.doc_id is null
union all
select a.doc_id as for_doc_id, a.doc_date, b.item_id as coa_id, c.item_name as coa_name, b.qty*b.total_price as total, a.remarks, 'Stock out' as doc_type, 'BAHANBAKU PEMBANTU' as group_name
from stock_out a
left join stock_out_detail b on a.co_id=b.co_id and a.doc_id=b.doc_id
left join items c on b.co_id=c.co_id and b.item_id=c.item_id and b.unit_id=c.unit_id
left join cancel_transactions d on a.co_id=d.co_id and a.doc_id=d.for_doc_id and d.status=1 and d.doc_type='ST' and (select period from get_period(d.doc_date))<=$P{period}
inner join reclass e on a.co_id=e.co_id and a.doc_id=e.for_doc_id and e.status=1
where a.co_id=$P{co_id} and a.status<>0 and a.doc_type='PKS' and a.doc_id_rm like $P{doc_id}||'%' and a.doc_type like $P{type}||'%' and (select period from get_period(a.doc_date)) like $P{period}||'%' and d.doc_id is null
union all
select a.doc_id as for_doc_id, a.doc_date, b.item_id as coa_id, c.item_name as coa_name, a.total*(-1), a.remarks, 'Stock Opname' as doc_type, 'BIAYA TIDAK LANGSUNG' as group_name
from reclass a
inner join stock_opname b on a.co_id=b.co_id and a.for_doc_id=b.doc_id and b.status=1 and b.item_type='RA'
left join items c on b.co_id=c.co_id and b.item_id=c.item_id and b.unit_id=c.unit_id
left join cancel_transactions d on a.co_id=d.co_id and a.doc_id=d.for_doc_id and d.status=1 and d.doc_type='RC' and (select period from get_period(d.doc_date))<=$P{period}
where a.co_id=$P{co_id} and a.status<>0 and a.doc_type='SO' and a.doc_type like $P{type}||'%' and (select period from get_period(a.doc_date)) like $P{period}||'%' and a.doc_id like $P{doc_id}||'%' and d.doc_id is null
union all
select a.doc_id as for_doc_id, a.doc_date, b.coa_id as coa_id, c.coa_name as coa_name, a.total, a.remarks, iif(a.doc_type='A', 'Penyusutan Aset PKS', iif(a.doc_type='TM','Stock out','')) as doc_type, 'BIAYA TIDAK LANGSUNG' as group_name
from reclass a
inner join acc_depr_asset b on a.co_id=b.co_id and a.for_doc_id=b.doc_id
inner join depreciation_asset c on b.co_id=c.co_id and b.coa_id=c.coa_id and c.coa_type='PKS' and c.reclass_hpp=1
left join cancel_transactions d on a.co_id=d.co_id and a.doc_id=d.for_doc_id and d.status=1 and d.doc_type='RC' and (select period from get_period(d.doc_date))<=$P{period}
where a.co_id=$P{co_id} and a.status<>0 and a.doc_type in('A') and a.doc_type like $P{type}||'%' and (select period from get_period(a.doc_date)) like $P{period}||'%' and a.doc_id like $P{doc_id}||'%' and d.doc_id is null
)where group_name like $P{group}||'%' order by group_name, doc_date asc]]>
		</queryString>
		<field name="FOR_DOC_ID" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="COA_ID" class="java.lang.String"/>
		<field name="COA_NAME" class="java.lang.String"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="DOC_TYPE" class="java.lang.String"/>
		<field name="GROUP_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<variable name="sub_total" class="java.math.BigDecimal" resetType="Group" resetGroup="group_name" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<group name="group_name">
			<groupExpression><![CDATA[$F{GROUP_NAME}]]></groupExpression>
		</group>
	</subDataset>
