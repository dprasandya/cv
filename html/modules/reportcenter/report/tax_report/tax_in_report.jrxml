	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="fromdate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="todate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="tax_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, iif(coalesce(a.vend_id,'')<>'', b.vend_name, c.cust_name) as vend_cust_name from tax_rpt a
left join vendor b on a.co_id=b.co_id and a.vend_id=b.vend_id
left join customer c on a.co_id=c.co_id and a.cust_id=c.cust_id
where a.co_id=$P{co_id} and a.id_type='IN' and a.doc_date between $P{fromdate} and $P{todate} and a.tax_id like iif(coalesce($P{tax_id},'')='','%',$P{tax_id})]]>
		</queryString>
		<field name="MODULE" class="java.lang.String"/>
		<field name="CUST_ID" class="java.lang.String"/>
		<field name="VEND_ID" class="java.lang.String"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="PPH" class="java.math.BigDecimal"/>
		<field name="PPN" class="java.math.BigDecimal"/>
		<field name="NOMINAL" class="java.math.BigDecimal"/>
		<field name="TAX_ID" class="java.lang.String"/>
		<field name="TAX_NO" class="java.lang.String"/>
		<field name="TAX_DATE" class="java.sql.Date"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="ID_TYPE" class="java.lang.String"/>
		<field name="VEND_CUST_NAME" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="nominal" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{NOMINAL}]]></variableExpression>
		</variable>
		<variable name="ppn" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPN}]]></variableExpression>
		</variable>
		<variable name="pph" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{PPH}]]></variableExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
	</subDataset>
