	<style name="Crosstab Data Text" hAlign="Center"/>
	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="year" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select extract(month from a.doc_date) as month_int, sum(a.qty) as qty
from salesorder a where a.co_id=$P{co_id} and a.status in(1,3) and a.doc_type in('S','T') and extract(year from doc_date)=$P{year}
group by month_int]]>
		</queryString>
		<field name="MONTH_INT" class="java.lang.Integer"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="TableDataCustomer" uuid="f5879d52-7d9a-41e4-b4c2-94711a1b9fe5">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="year" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select b.cust_name, extract(month from a.doc_date) as month_int, sum(a.qty) as qty
from salesorder a
left join customer b on a.co_id=b.co_id and a.cust_id=b.cust_id
where a.co_id=$P{co_id} and a.status in(1,3) and a.doc_type in('S','T') and extract(year from doc_date)=$P{year}
group by month_int, b.cust_name]]>
		</queryString>
		<field name="CUST_NAME" class="java.lang.String"/>
		<field name="MONTH_INT" class="java.lang.Integer"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<subDataset name="TableDataItem" uuid="8b182ac2-2bb6-4db5-a504-eb42e44c5a64">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="year" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select c.form_name, extract(month from a.doc_date) as month_int, sum(a.qty) as qty
from salesorder a
left join items b on a.co_id=b.co_id and a.item_id=b.item_id
left join form c on b.co_id=c.co_id and b.form_id=c.form_id
where a.co_id=$P{co_id} and a.status in(1,3) and a.doc_type in('S','T') and extract(year from doc_date)=$P{year}
group by month_int, c.form_name]]>
		</queryString>
		<field name="FORM_NAME" class="java.lang.String"/>
		<field name="MONTH_INT" class="java.lang.Integer"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="year" class="java.lang.String">
