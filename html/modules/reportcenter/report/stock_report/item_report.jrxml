	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="item_type" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="warehouse_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="item_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_date" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="project_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="costcode_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, iif(a.qty_begin=0,0,(a.total_bb_begin+total_ohp_begin)/a.qty_begin) as price_begin,iif(a.qty_in=0,0,(a.total_bb_in+total_ohp_in)/a.qty_in) as price_in,iif(a.qty_out=0,0,(a.total_bb_out+total_ohp_out)/a.qty_out) as price_out,iif(a.qty_ending=0,0,(a.total_bb_ending+total_ohp_ending)/a.qty_ending) as price_ending from rpt_items_inventory($P{item_id},$P{warehouse_id},$P{item_type},$P{costcode_id},$P{project_id},$P{doc_date},$P{co_id}) a where not (qty_begin=0 and qty_in=0 and qty_out=0)
order by item_id asc]]>
		</queryString>
		<field name="TOTAL_OHP_ENDING" class="java.math.BigDecimal"/>
		<field name="TOTAL_BB_ENDING" class="java.math.BigDecimal"/>
		<field name="QTY_ENDING" class="java.math.BigDecimal"/>
		<field name="TOTAL_OHP_OUT" class="java.math.BigDecimal"/>
		<field name="TOTAL_BB_OUT" class="java.math.BigDecimal"/>
		<field name="QTY_OUT" class="java.math.BigDecimal"/>
		<field name="TOTAL_OHP_IN" class="java.math.BigDecimal"/>
		<field name="TOTAL_BB_IN" class="java.math.BigDecimal"/>
		<field name="QTY_IN" class="java.math.BigDecimal"/>
		<field name="TOTAL_OHP_BEGIN" class="java.math.BigDecimal"/>
		<field name="TOTAL_BB_BEGIN" class="java.math.BigDecimal"/>
		<field name="QTY_BEGIN" class="java.math.BigDecimal"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="ITEM_NAME" class="java.lang.String"/>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="WAREHOUSE_NAME" class="java.lang.String"/>
		<field name="WAREHOUSE_ID" class="java.lang.String"/>
		<field name="COSTCODE_NAME" class="java.lang.String"/>
		<field name="COSTCODE_ID" class="java.lang.String"/>
		<field name="PROJECT_NAME" class="java.lang.String"/>
		<field name="PROJECT_ID" class="java.lang.String"/>
		<field name="PRICE_BEGIN" class="java.math.BigDecimal"/>
		<field name="PRICE_IN" class="java.math.BigDecimal"/>
		<field name="PRICE_OUT" class="java.math.BigDecimal"/>
		<field name="PRICE_ENDING" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="QTY BEGIN" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY_BEGIN}]]></variableExpression>
		</variable>
		<variable name="QTY IN" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY_IN}]]></variableExpression>
		</variable>
		<variable name="QTY OUT" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY_OUT}]]></variableExpression>
		</variable>
		<variable name="QTY ENDING" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY_ENDING}]]></variableExpression>
		</variable>
		<variable name="TOTAL BEGIN" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_BB_BEGIN}.add($F{TOTAL_OHP_BEGIN})]]></variableExpression>
		</variable>
		<variable name="TOTAL IN" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_BB_IN}.add($F{TOTAL_OHP_IN})]]></variableExpression>
		</variable>
		<variable name="TOTAL OUT" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_BB_OUT}.add($F{TOTAL_OHP_OUT})]]></variableExpression>
		</variable>
		<variable name="TOTAL ENDING" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL_BB_ENDING}.add($F{TOTAL_OHP_ENDING})]]></variableExpression>
		</variable>
