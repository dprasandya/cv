	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="item_type" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="fromdate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="todate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="item_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="module" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="warehouse_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="project_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="costcode_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.warehouse_name, c.project_name, d.costcode_name from items_inventory_detail a
left join warehouse b on a.co_id=b.co_id and a.warehouse_id=b.warehouse_id
left join project c on a.co_id=c.co_id and a.project_id=c.project_id
left join costcode d on a.co_id=d.co_id and a.costcode_id=d.costcode_id
where a.co_id=$P{co_id} and a.doc_date between $P{fromdate} and $P{todate} and a.item_type=$P{item_type} and a.item_id like $P{item_id}||'%' and a.module like $P{module}||'%' and a.warehouse_id like iif(coalesce($P{warehouse_id},'')='','%', $P{warehouse_id}) and a.project_id like $P{project_id}||'%' and a.costcode_id like $P{costcode_id}||'%'
order by a.doc_date, doc_id asc]]>
		</queryString>
		<field name="TIMEINPUT" class="java.sql.Timestamp"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<field name="TOTAL_PRICE" class="java.math.BigDecimal"/>
		<field name="PRICE_OHP" class="java.math.BigDecimal"/>
		<field name="PRICE_BB" class="java.math.BigDecimal"/>
		<field name="QTY" class="java.math.BigDecimal"/>
