			<variableExpression><![CDATA[$V{QTY OUT}.doubleValue() - $V{QTY IN}.doubleValue()]]></variableExpression>
		</variable>
		<variable name="QTY IN_SUB" class="java.math.BigDecimal" resetType="Group" resetGroup="doc_id" calculation="Sum">
