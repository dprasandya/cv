			<variableExpression><![CDATA[$F{TOTAL_NEW}]]></variableExpression>
		</variable>
		<variable name="QTY_OUTSTANDING_SUB" class="java.math.BigDecimal" resetType="Group" resetGroup="doc_id" incrementType="Group" incrementGroup="doc_id" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}.doubleValue() - $V{QTY IN_SUB}.doubleValue()]]></variableExpression>
		</variable>
