	<subDataset name="TableData" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="fromdate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="todate" class="java.util.Date">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="cust_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="warehouse_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="item_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.item_id, a.item_name, a.unit_id, iif(a.item_type='cost','Cost', b.type_name) as type_name, sum(a.qty) as qty, sum(a.total) as total  from rpt_production_detail($P{warehouse_id}, $P{item_id}, $P{cust_id},$P{doc_id},$P{todate},$P{fromdate},$P{co_id}) a
left join types b on a.item_type=b.type_id
group by a.item_id, a.item_name, a.unit_id, type_name
order by type_name, a.item_name asc]]>
		</queryString>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="ITEM_NAME" class="java.lang.String"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="TYPE_NAME" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="TOTAL" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
		<variable name="qty sub" class="java.math.BigDecimal" resetType="Group" resetGroup="type_name" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
		<variable name="price" class="java.lang.Double">
			<variableExpression><![CDATA[$F{TOTAL}.doubleValue() / $F{QTY}.doubleValue()]]></variableExpression>
		</variable>
		<variable name="total" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<variable name="total_sub" class="java.math.BigDecimal" resetType="Group" resetGroup="type_name" calculation="Sum">
			<variableExpression><![CDATA[$F{TOTAL}]]></variableExpression>
		</variable>
		<variable name="price_sub" class="java.lang.Double" resetType="Group" resetGroup="type_name">
			<variableExpression><![CDATA[$V{total_sub}.doubleValue() / $V{qty sub}.doubleValue()]]></variableExpression>
		</variable>
		<variable name="price_total" class="java.lang.Double">
			<variableExpression><![CDATA[$V{total}.doubleValue() / $V{qty}.doubleValue()]]></variableExpression>
		</variable>
		<group name="type_name">
			<groupExpression><![CDATA[$F{TYPE_NAME}]]></groupExpression>
		</group>
	</subDataset>
