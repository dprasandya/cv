	<subDataset name="SalesOrder" uuid="a10c719c-b9f0-4b23-9faf-c92e808ce880">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from salesorder_address_send where co_id=$P{co_id} and doc_id=$P{doc_id}]]>
		</queryString>
		<field name="STATUS" class="java.lang.String"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="CONTACT" class="java.lang.String"/>
		<field name="ADDRESS" class="java.lang.String"/>
		<field name="CITY" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="CUST_ID" class="java.lang.String"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="CO_ID" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="Production" uuid="b11930fb-8cbd-4cf5-a42f-8c842a13e152">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.*, b.qty from production a
left join production_fg b on a.co_id=b.co_id and a.doc_id=b.doc_id
where a.co_id=$P{co_id} and a.doc_type='FG' and a.status=1 and a.for_doc_id=$P{doc_id}
order by a.doc_date asc]]>
		</queryString>
		<field name="TIMEEDIT" class="java.sql.Timestamp"/>
		<field name="TIMEINPUT" class="java.sql.Timestamp"/>
		<field name="USEREDIT" class="java.lang.String"/>
		<field name="USERINPUT" class="java.lang.String"/>
		<field name="REMARKS" class="java.lang.String"/>
		<field name="STATUS" class="java.lang.String"/>
		<field name="SHIFT_USER" class="java.lang.String"/>
		<field name="SHIFT" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="SEQ_ID" class="java.lang.Integer"/>
		<field name="CO_ID" class="java.lang.String"/>
		<field name="FOR_DOC_ID" class="java.lang.String"/>
		<field name="DOC_TYPE" class="java.lang.String"/>
		<field name="CUST_ID" class="java.lang.String"/>
		<field name="ITEM_ID" class="java.lang.String"/>
		<field name="UNIT_ID" class="java.lang.String"/>
		<field name="WAREHOUSE_ID" class="java.lang.String"/>
		<field name="DOC_ID_RM" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="deliveryorder" uuid="a98a1dd6-e25b-40fd-84e0-cbc693666498">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select a.doc_id, a.doc_date, b.address, b.city, iif(a.doc_type='D', b.qty, b.qty*(-1)) as qty, b.remarks from deliveryorder a
left join deliveryorder_address_send b on a.co_id=b.co_id and a.doc_id=b.doc_id
where a.co_id=$P{co_id} and a.status=1 and a.for_doc_id=$P{doc_id}
order by a.doc_date asc]]>
		</queryString>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="ADDRESS" class="java.lang.String"/>
		<field name="CITY" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="ar sale" uuid="f0aa0db8-bea0-4ae5-8c64-c6fd15d4d3b3">
		<parameter name="co_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select doc_date, doc_id, qty , remarks from ar_sale where co_id=$P{co_id} and status=1 and for_doc_id=$P{doc_id}]]>
		</queryString>
		<field name="DOC_DATE" class="java.sql.Date"/>
		<field name="DOC_ID" class="java.lang.String"/>
		<field name="QTY" class="java.math.BigDecimal"/>
		<field name="REMARKS" class="java.lang.String"/>
		<variable name="AUTONUMBER" class="java.lang.Integer" calculation="Count">
			<variableExpression><![CDATA[$V{AUTONUMBER}]]></variableExpression>
			<initialValueExpression><![CDATA[new Integer(1)]]></initialValueExpression>
		</variable>
		<variable name="qty" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{QTY}]]></variableExpression>
		</variable>
	</subDataset>
	<parameter name="LOGOURL" class="java.lang.String"/>
	<parameter name="co_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="doc_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select a.doc_id, a.doc_date, a.cust_id, b.cust_name, a.item_id, c.item_name, a.qty, a.unit_id, d.co_name from salesorder a
left join customer b on a.co_id=b.co_id and a.cust_id=b.cust_id
left join items c on a.co_id=c.co_id and a.item_id=c.item_id
left join company d on a.co_id=d.co_id
where a.co_id=$P{co_id} and doc_id=$P{doc_id}]]>
	</queryString>
	<field name="DOC_ID" class="java.lang.String"/>
	<field name="DOC_DATE" class="java.sql.Date"/>
	<field name="CUST_ID" class="java.lang.String"/>
	<field name="CUST_NAME" class="java.lang.String"/>
	<field name="ITEM_ID" class="java.lang.String"/>
	<field name="ITEM_NAME" class="java.lang.String"/>
	<field name="QTY" class="java.math.BigDecimal"/>
	<field name="UNIT_ID" class="java.lang.String"/>
	<field name="CO_NAME" class="java.lang.String"/>
