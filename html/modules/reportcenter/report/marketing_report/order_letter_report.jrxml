		<parameter name="doc_id" class="java.lang.String">
			<defaultValueExpression><![CDATA[]]></defaultValueExpression>
		</parameter>
		<queryString>
			<![CDATA[select * from salesorder_address_send where co_id=$P{co_id} and doc_id=$P{doc_id} and qty > 0]]>
		</queryString>
