	</parameter>
	<queryString>
		<![CDATA[select b.cust_name, b.address, b.city, a.*, c.sales_name, d.city as city_company, d.co_name
from salesorder a
inner join customer b on a.co_id=b.co_id and a.cust_id=b.cust_id
left join salesman c on a.co_id=c.co_id and a.sales_id=c.sales_id
left join company d on a.co_id=d.co_id
where a.doc_id=$P{doc_id} and a.co_id=$P{co_id}]]>
	</queryString>
	<field name="CUST_NAME" class="java.lang.String"/>
